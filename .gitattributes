# Normalize line endings to LF on checkout for all text files
* text=auto eol=lf

# Python source files
*.py text eol=lf

# TOML / YAML / Markdown
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf

# Binary files - never convert
*.png binary
*.jpg binary
*.gif binary
*.svg text eol=lf
